generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String @id @default(uuid())
  name     String
  email    String @unique
  password String

  created_at DateTime? @default(now())
  updated_at DateTime? @default(now())

  role String @default("user")

  balance Float @default(0)
  coins   Int   @default(0)

  level Int @default(1)
  xp    Int @default(0)

  gameResults  GameResult[]
  quizResults  QuizResult[]
  transactions Transaction[]
  carts        Cart[]
  inventory Inventory[]
  favorites Favorite[]
  comments Comment[]
  expeditions Expedition[]

  @@map("users")
}

model Transaction {
  id         String   @id @default(uuid())
  userId     String
  type       String
  amount     Int
  source     String
  created_at DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id])
}

model Game {
  id         String       @id @default(uuid())
  name       String
  slug       String
  baseCoins  Int          @default(100)
  baseXP     Int          @default(50)
  created_at DateTime     @default(now())
  results    GameResult[]
}

model Animal {

  id          String   @id @default(uuid())
  name        String
  type        String
  size        String?
  image       String?
  created_at  DateTime @default(now())
  periodoId   String
  dieta       String?
  description String?

  habitat        String?
  clima          String?
  descoberta     String?
  local          String?
  scientificName String?

  periodo Periodo @relation(fields: [periodoId], references: [id])

  favorites Favorite[]

  @@map("animals")
}

model Favorite {
  id String @id @default(uuid())

  userId   String
  animalId String

  created_at DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id])
  animal Animal @relation(fields: [animalId], references: [id])


  @@unique([userId, animalId])
  @@map("favorites")
}

model Periodo {
  id          String   @id @default(uuid())
  name        String
  description String?
  image       String?
  eraId       String
  era         Era      @relation(fields: [eraId], references: [id])
  animals     Animal[]

  @@map("periodos")
}

model Era {
  id          String    @id @default(uuid())
  name        String
  description String?
  image       String?
  created_at  DateTime  @default(now())
  periodos    Periodo[]

  @@map("eras")
}

model Product {
  id          String  @id @default(uuid())
  name        String
  price       Float
  description String?
  image       String?

  created_at DateTime @default(now())

  items     CartItem[]
  inventory Inventory[]
  comments Comment[]

  @@map("products")
}

model Cart {
  id         String     @id @default(uuid())
  user_id    String
  status     String     @default("open")
  created_at DateTime   @default(now())
  user       User       @relation(fields: [user_id], references: [id])
  items      CartItem[]

  @@map("carts")
}

model CartItem {
  id         String  @id @default(uuid())
  quantity   Int
  cart_id    String
  product_id String
  cart       Cart    @relation(fields: [cart_id], references: [id])
  product    Product @relation(fields: [product_id], references: [id])

  @@map("cart_items")
}

model GameResult {
  id         String   @id @default(uuid())
  user_id    String
  game_id    String?
  score      Int
  coins      Int
  xp         Int
  created_at DateTime @default(now())
  game       Game?    @relation(fields: [game_id], references: [id])
  user       User     @relation(fields: [user_id], references: [id])
}

model QuizQuestion {
  id         String   @id @default(uuid())
  question   String
  optionA    String
  optionB    String
  optionC    String
  optionD    String
  correct    String
  difficulty String   @default("easy")
  created_at DateTime @default(now())
}

model QuizResult {
  id          String   @id @default(uuid())
  userId      String
  score       Int
  hits        Int
  coinsEarned Int
  xpEarned    Int
  created_at  DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id])
}

model Inventory {
  id String @id @default(uuid())

  userId    String
  productId String

  quantity Int @default(1)

  created_at DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Comment {
  id String @id @default(uuid())

  content String

  created_at DateTime @default(now())

  userId String
  productId String

  user User @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  @@map("comments")
}

model Expedition {
  id          String   @id @default(uuid())

  userId      String
  title       String
  description String?
  status      String   @default("completed")
  location    String?

  rewardXp    Int      @default(0)
  rewardCoins Int      @default(0)

  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
